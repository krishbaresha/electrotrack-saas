generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  EXPIRED
  BLOCKED
  CANCELLED
  PENDING_DELETION
}

enum FeatureStatus {
  STABLE
  BETA
  EXPERIMENTAL
  COMING_SOON
  DEPRECATED
  HIDDEN
  INTERNAL
}

enum BillingCycle {
  MONTHLY
  YEARLY
  LIFETIME
  TRIAL
  CUSTOM
}

enum FeatureAccess {
  NONE
  READ
  WRITE
  FULL
}

enum Role {
  platform_admin
  owner
  cashier
  inventory_manager
  accountant
  technician
}

enum UnitStatus {
  in_stock
  sold
  return_pending
  returned
  damaged
  repair
  reserved
}

enum UnitCondition {
  new
  refurbished
  damaged
}

enum SaleStatus {
  completed
  voided
  partial_return
}

enum PaymentMethod {
  cash
  easypaisa
  jazzcash
  card
  bank_transfer
}

enum ReturnType {
  cash_refund
  store_credit
  exchange
}

enum ReturnStatus {
  pending
  approved
  rejected
  completed
}

enum POStatus {
  draft
  sent
  partial
  received
  cancelled
}

enum ShippingStatus {
  pending
  dispatched
  delivered
  returned
}

enum TransactionStatus {
  SUCCESS
  FAILED
  PENDING
}

// ─── Tenant model ──────────────────────────────────────────────────────────

model Tenant {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @db.VarChar(255)
  slug             String   @unique @db.VarChar(100)
  status           TenantStatus @default(ACTIVE)
  plan             String   @default("trial") @db.VarChar(50)
  trialEndsAt      DateTime? @map("trial_ends_at")
  currentPeriodEnd DateTime? @map("current_period_end")
  maxUsers         Int      @default(5) @map("max_users")
  onlineSellingEnabled Boolean  @default(false) @map("online_selling_enabled")
  appAccessEnabled     Boolean   @default(false) @map("app_access_enabled")
  isWarehouseEnabled   Boolean   @default(false) @map("is_warehouse_enabled")
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  users            User[]
  settings         ShopSettings[]
  products         Product[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  goodsReceived    GoodsReceivedNote[]
  inventoryUnits   InventoryUnit[]
  customers        Customer[]
  creditRecords    CreditRecord[]
  sales            Sale[]
  returns          Return[]
  reconciliations  CashReconciliation[]
  expenses         Expense[]
  courierPayouts   CourierPayout[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  transactions     Transaction[]
  integrityScans   IntegrityScan[]

  // PCC additions
  subscriptionPlanId    String?   @map("subscription_plan_id") @db.Uuid
  subscriptionPlan      SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  subscriptionStartAt   DateTime? @map("subscription_start_at")
  subscriptionRenewedAt DateTime? @map("subscription_renewed_at")
  gracePeriodDays       Int       @default(7) @map("grace_period_days")
  overrides             TenantFeatureOverride[]
  history               TenantLicenseHistory[]

  @@map("tenants")
}

// ─── Table 1: users ───────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role
  isActive     Boolean  @default(true) @map("is_active")
  tenantId     String?  @map("tenant_id") @db.Uuid
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions  String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Multiple relations to same model require distinct names
  products                 Product[]
  purchaseOrders           PurchaseOrder[]
  goodsReceived            GoodsReceivedNote[]
  auditLogs                AuditLog[]
  notifications            Notification[]
  refreshTokens            RefreshToken[]
  salesAsCashier           Sale[]               @relation("SalesSoldBy")
  salesDiscountApproved    Sale[]               @relation("SalesDiscountApproved")
  salesVoided              Sale[]               @relation("SalesVoided")
  returnsRequested         Return[]             @relation("ReturnsRequestedBy")
  returnsReviewed          Return[]             @relation("ReturnsReviewedBy")
  reconciliationsSubmitted CashReconciliation[] @relation("ReconciliationsSubmittedBy")
  reconciliationsReviewed  CashReconciliation[] @relation("ReconciliationsReviewedBy")
  expenses                 Expense[]            @relation("ExpensesCreatedBy")
  courierPayouts           CourierPayout[]      @relation("PayoutsCreatedBy")

  @@map("users")
}

// ─── Table 2: refresh_tokens ──────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.Text
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── Table 3: shop_settings ───────────────────────────────────────────────────

model ShopSettings {
  id                        String   @id @default(uuid()) @db.Uuid
  shopName                  String   @map("shop_name") @db.VarChar(255)
  lowStockThreshold         Int      @default(2) @map("low_stock_threshold")
  deadStockDays             Int      @default(60) @map("dead_stock_days")
  maxDiscountWithoutOtp     Decimal  @default(500) @map("max_discount_without_otp") @db.Decimal(10, 2)
  returnFraudWindowDays     Int      @default(30) @map("return_fraud_window_days")
  returnFraudCountThreshold Int      @default(2) @map("return_fraud_count_threshold")
  // Invoice template fields
  logoUrl                   String?  @map("logo_url") @db.Text
  invoiceFontFamily         String   @default("Inter") @map("invoice_font_family") @db.VarChar(100)
  invoicePrimaryColor       String   @default("#ffffff") @map("invoice_primary_color") @db.VarChar(7)
  invoiceAccentColor        String   @default("#14b8a6") @map("invoice_accent_color") @db.VarChar(7)
  invoiceFooterNotes        String?  @map("invoice_footer_notes") @db.Text
  invoiceWatermarkText      String?  @map("invoice_watermark_text") @db.VarChar(255)
  invoiceShowWatermark      Boolean  @default(false) @map("invoice_show_watermark")
  quickAddOns               Json     @default("[{\"name\": \"Bag\", \"amount\": 100, \"enabled\": true}, {\"name\": \"Gift Wrap\", \"amount\": 150, \"enabled\": true}, {\"name\": \"Delivery\", \"amount\": 500, \"enabled\": false}]") @map("quick_add_ons")
  tenantId                  String   @map("tenant_id") @db.Uuid
  tenant                    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("shop_settings")
}

// ─── Table 4: products ────────────────────────────────────────────────────────

model Product {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @db.VarChar(255)
  sku              String?  @db.VarChar(100)
  brand            String?  @db.VarChar(100)
  category         String?  @db.VarChar(100)
  description      String?  @db.Text
  shortDescription String?  @map("short_description") @db.VarChar(500)
  aiSummary        String?  @map("ai_summary") @db.Text
  imageUrl         String?  @map("image_url") @db.Text
  tags             String[] @default([])
  specifications   Json?    @db.Json
  costPrice        Decimal? @map("cost_price") @db.Decimal(10, 2)
  sellingPrice     Decimal  @map("selling_price") @db.Decimal(10, 2)
  comparePrice     Decimal? @map("compare_price") @db.Decimal(10, 2)
  warrantyMonths   Int      @default(0) @map("warranty_months")
  isActive         Boolean  @default(true) @map("is_active")
  createdById      String?  @map("created_by_id") @db.Uuid
  createdBy        User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  tenantId         String   @map("tenant_id") @db.Uuid
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now()) @map("created_at")

  inventoryUnits     InventoryUnit[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([tenantId])
  @@map("products")
}

// ─── Table 5: suppliers ───────────────────────────────────────────────────────

model Supplier {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  contactName String?  @map("contact_name") @db.VarChar(100)
  phone       String?  @db.VarChar(20)
  email       String?  @db.VarChar(255)
  address     String?  @db.Text
  tenantId    String   @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  purchaseOrders PurchaseOrder[]
  creditRecords  CreditRecord[]

  @@index([tenantId])
  @@map("suppliers")
}

// ─── Table 6: purchase_orders ─────────────────────────────────────────────────

model PurchaseOrder {
  id          String    @id @default(uuid()) @db.Uuid
  supplierId  String?   @map("supplier_id") @db.Uuid
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  status      POStatus  @default(draft)
  totalAmount Decimal?  @map("total_amount") @db.Decimal(12, 2)
  notes       String?   @db.Text
  createdById String?   @map("created_by_id") @db.Uuid
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  tenantId    String    @map("tenant_id") @db.Uuid
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  items PurchaseOrderItem[]
  grns  GoodsReceivedNote[]

  @@index([tenantId])
  @@map("purchase_orders")
}

// ─── Table 7: purchase_order_items ────────────────────────────────────────────

model PurchaseOrderItem {
  id              String        @id @default(uuid()) @db.Uuid
  purchaseOrderId String        @map("purchase_order_id") @db.Uuid
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String        @map("product_id") @db.Uuid
  product         Product       @relation(fields: [productId], references: [id])
  quantityOrdered Int           @map("quantity_ordered")
  unitCostPrice   Decimal       @map("unit_cost_price") @db.Decimal(10, 2)

  @@map("purchase_order_items")
}

// ─── Table 8: goods_received_notes ────────────────────────────────────────────

model GoodsReceivedNote {
  id              String         @id @default(uuid()) @db.Uuid
  purchaseOrderId String?        @map("purchase_order_id") @db.Uuid
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  receivedById    String?        @map("received_by_id") @db.Uuid
  receivedBy      User?          @relation(fields: [receivedById], references: [id], onDelete: SetNull)
  notes           String?        @db.Text
  tenantId        String         @map("tenant_id") @db.Uuid
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  receivedAt      DateTime       @default(now()) @map("received_at")

  inventoryUnits InventoryUnit[]

  @@index([tenantId])
  @@map("goods_received_notes")
}

// ─── Table 9: inventory_units ─────────────────────────────────────────────────

model InventoryUnit {
  id            String             @id @default(uuid()) @db.Uuid
  serialNumber  String             @map("serial_number") @db.VarChar(100)
  productId     String             @map("product_id") @db.Uuid
  product       Product            @relation(fields: [productId], references: [id])
  status        UnitStatus         @default(in_stock)
  condition     UnitCondition      @default(new)
  purchasePrice Decimal?           @map("purchase_price") @db.Decimal(10, 2)
  receivedAt    DateTime           @default(now()) @map("received_at")
  grnId         String?            @map("grn_id") @db.Uuid
  grn           GoodsReceivedNote? @relation(fields: [grnId], references: [id], onDelete: SetNull)
  notes         String?            @db.Text
  tenantId      String             @map("tenant_id") @db.Uuid
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  saleItems SaleItem[]
  returns   Return[]

  @@unique([tenantId, serialNumber])
  @@index([serialNumber])
  @@index([status])
  @@index([productId, status])
  @@index([tenantId])
  @@map("inventory_units")
}

// ─── Table 10: customers ──────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  phone     String   @db.VarChar(20)
  email     String?  @db.VarChar(255)
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  sales Sale[]
  creditRecords CreditRecord[]

  @@unique([tenantId, phone])
  @@index([phone])
  @@index([tenantId])
  @@map("customers")
}

// ─── Table 11: sales ──────────────────────────────────────────────────────────

model Sale {
  id                   String        @id @default(uuid()) @db.Uuid
  invoiceNumber        String        @map("invoice_number") @db.VarChar(50)
  customerId           String?       @map("customer_id") @db.Uuid
  customer             Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  soldById             String?       @map("sold_by_id") @db.Uuid
  soldBy               User?         @relation("SalesSoldBy", fields: [soldById], references: [id], onDelete: SetNull)
  paymentMethod        PaymentMethod @map("payment_method")
  subtotal             Decimal       @db.Decimal(12, 2)
  discountAmount       Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  discountApprovedById String?       @map("discount_approved_by_id") @db.Uuid
  discountApprovedBy   User?         @relation("SalesDiscountApproved", fields: [discountApprovedById], references: [id], onDelete: SetNull)
  totalAmount          Decimal       @map("total_amount") @db.Decimal(12, 2)
  status               SaleStatus    @default(completed)
  voidReason           String?       @map("void_reason") @db.Text
  voidedById           String?       @map("voided_by_id") @db.Uuid
  voidedBy             User?         @relation("SalesVoided", fields: [voidedById], references: [id], onDelete: SetNull)
  tenantId             String        @map("tenant_id") @db.Uuid
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isOnline             Boolean       @default(false) @map("is_online")
  customerCity         String?       @map("customer_city") @db.VarChar(100)
  trackingId           String?       @map("tracking_id") @db.VarChar(100)
  deliveryCharge       Decimal       @default(0) @map("delivery_charge") @db.Decimal(10, 2)
  advanceAmount        Decimal       @default(0) @map("advance_amount") @db.Decimal(10, 2)
  codAmount            Decimal       @default(0) @map("cod_amount") @db.Decimal(10, 2)
  additionalCharges    Decimal       @default(0) @map("additional_charges") @db.Decimal(10, 2)
  description          String?       @db.Text
  shippingStatus       ShippingStatus @default(pending) @map("shipping_status")
  payoutReceivedAt     DateTime?      @map("payout_received_at")
  refundLossAmount     Decimal?       @map("refund_loss_amount") @db.Decimal(10, 2)
  createdAt            DateTime      @default(now()) @map("created_at")

  items   SaleItem[]
  returns Return[]

  @@unique([tenantId, invoiceNumber])
  @@index([invoiceNumber])
  @@index([createdAt])
  @@index([soldById])
  @@index([tenantId])
  @@map("sales")
}

// ─── Table 12: sale_items ─────────────────────────────────────────────────────

model SaleItem {
  id              String        @id @default(uuid()) @db.Uuid
  saleId          String        @map("sale_id") @db.Uuid
  sale            Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  inventoryUnitId String        @map("inventory_unit_id") @db.Uuid
  inventoryUnit   InventoryUnit @relation(fields: [inventoryUnitId], references: [id])
  sellingPrice    Decimal       @map("selling_price") @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)

  @@map("sale_items")
}

// ─── Table 13: returns ────────────────────────────────────────────────────────

model Return {
  id              String        @id @default(uuid()) @db.Uuid
  saleId          String        @map("sale_id") @db.Uuid
  sale            Sale          @relation(fields: [saleId], references: [id])
  inventoryUnitId String        @map("inventory_unit_id") @db.Uuid
  inventoryUnit   InventoryUnit @relation(fields: [inventoryUnitId], references: [id])
  requestedById   String?       @map("requested_by_id") @db.Uuid
  requestedBy     User?         @relation("ReturnsRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  reason          String        @db.Text
  returnType      ReturnType    @map("return_type")
  status          ReturnStatus  @default(pending)
  suspiciousFlag  Boolean       @default(false) @map("suspicious_flag")
  reviewedById    String?       @map("reviewed_by_id") @db.Uuid
  reviewedBy      User?         @relation("ReturnsReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNotes     String?       @map("review_notes") @db.Text
  refundAmount    Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  tenantId        String        @map("tenant_id") @db.Uuid
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now()) @map("created_at")
  resolvedAt      DateTime?     @map("resolved_at")

  @@index([status])
  @@index([createdAt])
  @@index([inventoryUnitId])
  @@index([tenantId])
  @@map("returns")
}

// ─── Table 14: cash_reconciliations ──────────────────────────────────────────

model CashReconciliation {
  id             String   @id @default(uuid()) @db.Uuid
  date           DateTime @db.Date
  openingBalance Decimal  @default(0) @map("opening_balance") @db.Decimal(10, 2)
  expectedCash   Decimal  @map("expected_cash") @db.Decimal(10, 2)
  actualCash     Decimal? @map("actual_cash") @db.Decimal(10, 2)
  variance       Decimal? @db.Decimal(10, 2)
  submittedById  String?  @map("submitted_by_id") @db.Uuid
  submittedBy    User?    @relation("ReconciliationsSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  reviewedById   String?  @map("reviewed_by_id") @db.Uuid
  reviewedBy     User?    @relation("ReconciliationsReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  notes          String?  @db.Text
  tenantId       String   @map("tenant_id") @db.Uuid
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([date])
  @@index([tenantId])
  @@map("cash_reconciliations")
}

// ─── Table 14.5: expenses ─────────────────────────────────────────────────────

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  amount      Decimal  @db.Decimal(10, 2)
  category    String   @db.VarChar(100)
  description String?  @db.Text
  date        DateTime @db.Date
  createdById String?  @map("created_by_id") @db.Uuid
  createdBy   User?    @relation("ExpensesCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  tenantId    String   @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([date])
  @@index([tenantId])
  @@map("expenses")
}

// ─── Table 14.6: courier_payouts ──────────────────────────────────────────────

model CourierPayout {
  id          String   @id @default(uuid()) @db.Uuid
  amount      Decimal  @db.Decimal(10, 2)
  courierName String?  @map("courier_name") @db.VarChar(100)
  date        DateTime @db.Date
  createdById String?  @map("created_by_id") @db.Uuid
  createdBy   User?    @relation("PayoutsCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  tenantId    String   @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([date])
  @@index([tenantId])
  @@map("courier_payouts")
}

// ─── Table 15: audit_logs ─────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  deviceInfo String?  @map("device_info") @db.Text
  tenantId   String?  @map("tenant_id") @db.Uuid
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([userId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([tenantId])
  @@map("audit_logs")
}

// ─── Table 16: notifications ──────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String?  @db.VarChar(100)
  message   String?  @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  actionUrl String?  @map("action_url") @db.Text
  tenantId  String?  @map("tenant_id") @db.Uuid
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([tenantId])
  @@map("notifications")
}

// ─── Table 17: transactions ──────────────────────────────────────────────────

model Transaction {
  id        String            @id @default(uuid()) @db.Uuid
  orderId   String            @unique @map("order_id") @db.VarChar(100)
  amount    Float
  status    TransactionStatus @default(PENDING)
  tenantId  String            @map("tenant_id") @db.Uuid
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([tenantId])
  @@map("transactions")
}

enum CreditType {
  CUSTOMER
  SUPPLIER
}

enum CreditStatus {
  PENDING
  PAID
}

model CreditRecord {
  id          String       @id @default(uuid()) @db.Uuid
  type        CreditType
  status      CreditStatus @default(PENDING)
  amount      Decimal      @db.Decimal(12, 2)
  paidAmount  Decimal      @default(0) @db.Decimal(12, 2) @map("paid_amount")
  dueAmount   Decimal      @db.Decimal(12, 2) @map("due_amount")
  description String?
  date        DateTime     @db.Date
  customerId  String?      @map("customer_id") @db.Uuid
  supplierId  String?      @map("supplier_id") @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  supplier    Supplier?    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([status])
  @@index([tenantId])
  @@map("credit_records")
}

model IntegrityScan {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  healthScore    Int              @map("health_score")
  overallHealth  Json             @map("overall_health") // { inventory: 98, sales: 100, ... }
  criticalCount  Int              @map("critical_count")
  highCount      Int              @map("high_count")
  mediumCount    Int              @map("medium_count")
  lowCount       Int              @map("low_count")
  infoCount      Int              @map("info_count")
  durationMs     Int              @map("duration_ms")
  createdAt      DateTime         @default(now()) @map("created_at")
  issues         IntegrityIssue[]

  @@index([tenantId])
  @@map("integrity_scans")
}

model IntegrityIssue {
  id                   String        @id @default(uuid()) @db.Uuid
  scanId               String        @map("scan_id") @db.Uuid
  scan                 IntegrityScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  type                 String        @db.VarChar(100) // duplicate_serial, orphan_unit, etc.
  severity             String        @db.VarChar(50)  // critical, high, medium, low, info
  entity               String?       @db.VarChar(100) // e.g. InventoryUnit, Product
  entityId             String?       @map("entity_id") @db.Uuid
  message              String        @db.Text
  repairable           Boolean       @default(false)
  requiresConfirmation Boolean       @default(false) @map("requires_confirmation")
  confidence           Int?          @default(100)    // Confidence score for heuristics
  estimatedChanges     Json?         @map("estimated_changes")
  createdAt            DateTime      @default(now()) @map("created_at")

  @@index([scanId])
  @@map("integrity_issues")
}

// ─── Platform Control Center Models ───────────────────────────────────────────

model FeatureCategory {
  id        String    @id @default(uuid()) @db.Uuid
  key       String    @unique @db.VarChar(100)
  name      String    @db.VarChar(100)
  features  Feature[]

  @@map("feature_categories")
}

model Feature {
  id              String          @id @default(uuid()) @db.Uuid
  key             String          @unique @db.VarChar(100)
  name            String          @db.VarChar(255)
  description     String?         @db.Text
  categoryId      String          @map("category_id") @db.Uuid
  category        FeatureCategory @relation(fields: [categoryId], references: [id])
  
  icon            String?         @db.VarChar(100)
  route           String?         @db.VarChar(255)
  menuOrder       Int             @default(0) @map("menu_order")
  sidebarVisible  Boolean         @default(true) @map("sidebar_visible")
  
  parentFeatureId String?         @map("parent_feature_id") @db.Uuid
  parentFeature   Feature?        @relation("FeatureHierarchy", fields: [parentFeatureId], references: [id])
  childFeatures   Feature[]       @relation("FeatureHierarchy")
  
  isSystemFeature Boolean         @default(false) @map("is_system_feature")
  version         String          @default("v1") @db.VarChar(50)
  minimumBuild    Int             @default(1) @map("minimum_build")
  status          FeatureStatus   @default(STABLE)
  globalEnabled   Boolean         @default(true) @map("global_enabled")
  
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  
  planFeatures    SubscriptionPlanFeature[]
  overrides       TenantFeatureOverride[]

  @@map("features")
}

model SubscriptionPlan {
  id           String                    @id @default(uuid()) @db.Uuid
  name         String                    @unique @db.VarChar(100)
  description  String?                   @db.Text
  price        Decimal                   @db.Decimal(10, 2)
  billingCycle BillingCycle              @default(MONTHLY) @map("billing_cycle")
  isActive     Boolean                   @default(true) @map("is_active")
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")

  planFeatures SubscriptionPlanFeature[]
  tenants      Tenant[]

  @@map("subscription_plans")
}

model SubscriptionPlanFeature {
  id        String        @id @default(uuid()) @db.Uuid
  planId    String        @map("plan_id") @db.Uuid
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureId String        @map("feature_id") @db.Uuid
  feature   Feature       @relation(fields: [featureId], references: [id], onDelete: Cascade)
  access    FeatureAccess @default(FULL)

  @@unique([planId, featureId])
  @@map("subscription_plan_features")
}

model TenantFeatureOverride {
  id        String        @id @default(uuid()) @db.Uuid
  tenantId  String        @map("tenant_id") @db.Uuid
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  featureId String        @map("feature_id") @db.Uuid
  feature   Feature       @relation(fields: [featureId], references: [id], onDelete: Cascade)
  access    FeatureAccess @default(FULL)
  enabledBy String?       @map("enabled_by") @db.VarChar(255)
  enabledAt DateTime      @default(now()) @map("enabled_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@unique([tenantId, featureId])
  @@map("tenant_feature_overrides")
}

model TenantLicenseHistory {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action      String       @db.VarChar(100)
  oldPlanName String?      @map("old_plan_name") @db.VarChar(100)
  newPlanName String?      @map("new_plan_name") @db.VarChar(100)
  details     Json?
  changedBy   String?      @map("changed_by") @db.VarChar(255)
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("tenant_license_history")
}
